{
  "name": "📋🚀 AUTOMAÇÃO COMPLETA: Diários TCM/TCE + Email (ÚNICO WORKFLOW)",
  "description": "Workflow único: Scrape → Claude → Compara → Se novo: Download → Upload → Email → Notifica Kausas → Log",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{"days": 1}],
          "triggerAtHour": 8,
          "triggerAtMinute": 0,
          "timezone": "America/Belem"
        }
      },
      "name": "⏰ Cron - 8h Diariamente",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "https://tcm.ioepa.com.br/busca/",
        "options": {
          "headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}
        }
      },
      "name": "🌐 Scrape TCM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [450, 100]
    },
    {
      "parameters": {
        "url": "https://www.tcepa.tc.br/diario-oficial",
        "options": {
          "headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}
        }
      },
      "name": "🌐 Scrape TCE",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [450, 450]
    },
    {
      "parameters": {
        "model": "claude-opus-4-6",
        "messages": {
          "values": [
            {
              "content": "Analise este HTML da página de busca do TCM/Pará e extraia:\n1. **data**: Data do diário mais recente em formato YYYY-MM-DD\n2. **url_pdf**: URL completa para download do PDF\n3. **titulo**: Título ou número do diário\n4. **descricao**: Breve descrição\n\nSe não encontrar, retorne data como null.\n\nRESPONDA APENAS EM JSON:\n{\"data\": \"YYYY-MM-DD\", \"url_pdf\": \"https://...\", \"titulo\": \"...\", \"descricao\": \"...\"}\n\nHTML:\n{{ $node[\"Scrape TCM\"].json.body.substring(0, 5000) }}",
              "role": "user"
            }
          ]
        },
        "maxTokens": 600
      },
      "name": "🤖 Claude - Analisar TCM",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [650, 100]
    },
    {
      "parameters": {
        "model": "claude-opus-4-6",
        "messages": {
          "values": [
            {
              "content": "Analise este HTML da página de diários do TCE/Pará e extraia:\n1. **data**: Data do diário mais recente em formato YYYY-MM-DD\n2. **url_pdf**: URL completa para download do PDF\n3. **titulo**: Título ou número do diário\n4. **descricao**: Breve descrição\n\nSe não encontrar, retorne data como null.\n\nRESPONDA APENAS EM JSON:\n{\"data\": \"YYYY-MM-DD\", \"url_pdf\": \"https://...\", \"titulo\": \"...\", \"descricao\": \"...\"}\n\nHTML:\n{{ $node[\"Scrape TCE\"].json.body.substring(0, 5000) }}",
              "role": "user"
            }
          ]
        },
        "maxTokens": 600
      },
      "name": "🤖 Claude - Analisar TCE",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [650, 450]
    },
    {
      "parameters": {
        "jsCode": "let tcmData = { orgao: 'TCM', data: null, url_pdf: null, titulo: null, descricao: null };\nlet tceData = { orgao: 'TCE', data: null, url_pdf: null, titulo: null, descricao: null };\n\ntry {\n  const tcmMsg = $node['Claude - Analisar TCM'].json.message.content;\n  tcmData = { ...tcmData, ...JSON.parse(tcmMsg) };\n} catch(e) { console.log('TCM parse error'); }\n\ntry {\n  const tceMsg = $node['Claude - Analisar TCE'].json.message.content;\n  tceData = { ...tceData, ...JSON.parse(tceMsg) };\n} catch(e) { console.log('TCE parse error'); }\n\nreturn [tcmData, tceData];"
      },
      "name": "📝 Parse Respostas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "resource": "recordApi",
        "method": "search",
        "table": "diarios",
        "filterBy": {
          "fields": [{"name": "orgao", "operator": "is", "value": "TCM"}]
        },
        "options": {"limit": 1, "sort": {"field": "data", "direction": "descending"}}
      },
      "name": "📊 Get Última Data TCM",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [1050, 100]
    },
    {
      "parameters": {
        "resource": "recordApi",
        "method": "search",
        "table": "diarios",
        "filterBy": {
          "fields": [{"name": "orgao", "operator": "is", "value": "TCE"}]
        },
        "options": {"limit": 1, "sort": {"field": "data", "direction": "descending"}}
      },
      "name": "📊 Get Última Data TCE",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "jsCode": "const tcmNovo = $input.all()[0].json;\nconst tceNovo = $input.all()[1].json;\nconst ultimaTcm = $node['Get Última Data TCM'].json?.records?.[0]?.data;\nconst ultimaTce = $node['Get Última Data TCE'].json?.records?.[0]?.data;\n\nconst tcmTemNovo = tcmNovo[0].data && (!ultimaTcm || tcmNovo[0].data > ultimaTcm);\nconst tceTemNovo = tceNovo[1].data && (!ultimaTce || tceNovo[1].data > ultimaTce);\n\nreturn {\n  tcm: { ...tcmNovo[0], novo: tcmTemNovo },\n  tce: { ...tceNovo[1], novo: tceTemNovo },\n  temNovo: tcmTemNovo || tceTemNovo,\n  timestamp: new Date().toISOString()\n};"
      },
      "name": "🔍 Comparar Datas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": [
            {"condition": "custom expression", "value": "={{ $node['Comparar Datas'].json.temNovo }}"}
          ]
        }
      },
      "name": "✅ Encontrou Novo?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1450, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $node['Comparar Datas'].json.tcm.url_pdf }}",
        "options": {"response": {"response": {"type": "arraybuffer"}}}
      },
      "name": "⬇️ Download PDF TCM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1650, 50]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $node['Comparar Datas'].json.tce.url_pdf }}",
        "options": {"response": {"response": {"type": "arraybuffer"}}}
      },
      "name": "⬇️ Download PDF TCE",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1650, 200]
    },
    {
      "parameters": {
        "resource": "file",
        "method": "upload",
        "bucket": "diarios",
        "fileName": "tcm_{{ $node['Comparar Datas'].json.tcm.data }}.pdf",
        "fileContent": "={{ $node['Download PDF TCM'].json.body }}"
      },
      "name": "☁️ Upload TCM",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [1850, 50]
    },
    {
      "parameters": {
        "resource": "file",
        "method": "upload",
        "bucket": "diarios",
        "fileName": "tce_{{ $node['Comparar Datas'].json.tce.data }}.pdf",
        "fileContent": "={{ $node['Download PDF TCE'].json.body }}"
      },
      "name": "☁️ Upload TCE",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [1850, 200]
    },
    {
      "parameters": {
        "resource": "recordApi",
        "method": "insert",
        "table": "diarios",
        "rows": {
          "values": [
            {"key": "orgao", "value": "TCM"},
            {"key": "data", "value": "={{ $node['Comparar Datas'].json.tcm.data }}"},
            {"key": "titulo", "value": "={{ $node['Comparar Datas'].json.tcm.titulo }}"},
            {"key": "arquivo", "value": "tcm_{{ $node['Comparar Datas'].json.tcm.data }}.pdf"},
            {"key": "url_original", "value": "={{ $node['Comparar Datas'].json.tcm.url_pdf }}"}
          ]
        }
      },
      "name": "💾 Inserir TCM no Banco",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [2050, 50]
    },
    {
      "parameters": {
        "resource": "recordApi",
        "method": "insert",
        "table": "diarios",
        "rows": {
          "values": [
            {"key": "orgao", "value": "TCE"},
            {"key": "data", "value": "={{ $node['Comparar Datas'].json.tce.data }}"},
            {"key": "titulo", "value": "={{ $node['Comparar Datas'].json.tce.titulo }}"},
            {"key": "arquivo", "value": "tce_{{ $node['Comparar Datas'].json.tce.data }}.pdf"},
            {"key": "url_original", "value": "={{ $node['Comparar Datas'].json.tce.url_pdf }}"}
          ]
        }
      },
      "name": "💾 Inserir TCE no Banco",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [2050, 200]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {"id": "1", "name": "orgao", "value": "={{ $node['Comparar Datas'].json.tcm.novo ? 'TCM' : 'TCE' }}", "type": "string"},
            {"id": "2", "name": "data_diario", "value": "={{ $node['Comparar Datas'].json.tcm.novo ? $node['Comparar Datas'].json.tcm.data : $node['Comparar Datas'].json.tce.data }}", "type": "string"},
            {"id": "3", "name": "titulo", "value": "={{ $node['Comparar Datas'].json.tcm.novo ? $node['Comparar Datas'].json.tcm.titulo : $node['Comparar Datas'].json.tce.titulo }}", "type": "string"},
            {"id": "4", "name": "descricao", "value": "{{ Diário oficial publicado }}", "type": "string"},
            {"id": "5", "name": "url_pdf", "value": "={{ $node['Comparar Datas'].json.tcm.novo ? $node['Comparar Datas'].json.tcm.url_pdf : $node['Comparar Datas'].json.tce.url_pdf }}", "type": "string"},
            {"id": "6", "name": "link_diario", "value": "=https://seuapp.com/diarios", "type": "string"}
          ]
        },
        "options": {}
      },
      "name": "📋 Extrair Dados (Set)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [2250, 100]
    },
    {
      "parameters": {
        "sendTo": "=leandrosmg0629@gmail.com",
        "subject": "=📋 Diário Oficial {{ $json.orgao }} Atualizado - {{ $now.format('DD/MM/YYYY') }}",
        "emailType": "html",
        "message": "=<!DOCTYPE html><html lang=\"pt-BR\"><head><meta charset=\"UTF-8\"><style>* { margin:0; padding:0; box-sizing:border-box; } body { background:#09090b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; } .wrap { max-width:580px; margin:32px auto; background:#18181b; border-radius:16px; overflow:hidden; border:1px solid #27272a; } .hero { background:linear-gradient(135deg,#f59e0b 0%,#d97706 100%); padding:36px 32px; } .badge { display:inline-block; background:rgba(0,0,0,.2); color:#000; font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; padding:4px 12px; border-radius:20px; margin-bottom:14px; } .hero h1 { font-size:24px; font-weight:800; color:#000; line-height:1.2; margin-bottom:6px; } .hero p { color:rgba(0,0,0,.6); font-size:13px; } .body { padding:28px 32px; } .diario-title { font-size:20px; font-weight:700; color:#fafafa; margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid #27272a; } .grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; } .field { background:#09090b; border-radius:10px; padding:14px; } .label { font-size:10px; font-weight:700; color:#52525b; text-transform:uppercase; letter-spacing:.1em; margin-bottom:6px; } .value { font-size:14px; color:#e4e4e7; font-weight:500; } .pill { display:inline-block; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600; background:rgba(245,158,11,.15); color:#f59e0b; } .cta { text-align:center; margin-bottom:4px; } .btn { display:inline-block; background:linear-gradient(135deg,#f59e0b,#d97706); color:#000 !important; font-weight:700; font-size:14px; padding:14px 36px; border-radius:10px; text-decoration:none; } .footer { padding:20px 32px; text-align:center; border-top:1px solid #27272a; } .logo { font-size:13px; font-weight:700; color:#f59e0b; margin-bottom:6px; } .footer p { font-size:11px; color:#52525b; line-height:1.8; }</style></head><body><div class=\"wrap\"><div class=\"hero\"><div class=\"badge\">Kauzas · Automação</div><h1>📋 Diário {{ $json.orgao }} Atualizado</h1><p>Um novo diário oficial foi publicado e está disponível</p></div><div class=\"body\"><div class=\"diario-title\">{{ $json.titulo }}</div><div class=\"grid\"><div class=\"field\"><div class=\"label\">Órgão</div><div class=\"value\"><span class=\"pill\">{{ $json.orgao }}</span></div></div><div class=\"field\"><div class=\"label\">Data</div><div class=\"value\">{{ $json.data_diario }}</div></div></div><div class=\"cta\"><a href=\"{{ $json.url_pdf }}\" class=\"btn\">📥 Baixar PDF →</a></div></div><div class=\"footer\"><div class=\"logo\">Kauzas – Gestão Jurídica</div><p>Automação de Diários Oficiais<br>Não responda este email · © 2026 Todos os direitos reservados</p></div></div></body></html>",
        "options": {}
      },
      "name": "📧 Enviar Email (Gmail)",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [2450, 100],
      "credentials": {}
    },
    {
      "parameters": {
        "resource": "recordApi",
        "method": "insert",
        "table": "notifications",
        "rows": {
          "values": [
            {"key": "msg", "value": "📋 Diário {{ $json.orgao }} atualizado! - {{ $now.format('DD/MM/YYYY HH:mm') }}"},
            {"key": "read", "value": false},
            {"key": "tipo_notificacao", "value": "diario"}
          ]
        }
      },
      "name": "🔔 Notificar Kausas",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [2650, 100]
    },
    {
      "parameters": {
        "resource": "recordApi",
        "method": "insert",
        "table": "diarios_log",
        "rows": {
          "values": [
            {"key": "orgao", "value": "AMBOS"},
            {"key": "status", "value": "sucesso"},
            {"key": "data_verificada", "value": "={{ $now.format('YYYY-MM-DD') }}"},
            {"key": "mensagem", "value": "✅ SUCESSO! {{ $json.orgao }} - PDF baixado, email enviado, Kausas notificada"}
          ]
        }
      },
      "name": "📝 Log Sucesso",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [2650, 250]
    },
    {
      "parameters": {
        "resource": "recordApi",
        "method": "insert",
        "table": "diarios_log",
        "rows": {
          "values": [
            {"key": "orgao", "value": "AMBOS"},
            {"key": "status", "value": "sem_atualizacao"},
            {"key": "data_verificada", "value": "={{ $now.format('YYYY-MM-DD') }}"},
            {"key": "mensagem", "value": "🔄 Nenhum diário novo encontrado"}
          ]
        }
      },
      "name": "📝 Log Sem Novo",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 2,
      "position": [1450, 450]
    }
  ],
  "connections": {
    "⏰ Cron - 8h Diariamente": {
      "main": [[{"node": "🌐 Scrape TCM", "type": "main", "index": 0}, {"node": "🌐 Scrape TCE", "type": "main", "index": 0}]]
    },
    "🌐 Scrape TCM": {"main": [[{"node": "🤖 Claude - Analisar TCM", "type": "main", "index": 0}]]},
    "🌐 Scrape TCE": {"main": [[{"node": "🤖 Claude - Analisar TCE", "type": "main", "index": 0}]]},
    "🤖 Claude - Analisar TCM": {"main": [[{"node": "📝 Parse Respostas", "type": "main", "index": 0}]]},
    "🤖 Claude - Analisar TCE": {"main": [[{"node": "📝 Parse Respostas", "type": "main", "index": 0}]]},
    "📝 Parse Respostas": {"main": [[{"node": "📊 Get Última Data TCM", "type": "main", "index": 0}, {"node": "📊 Get Última Data TCE", "type": "main", "index": 0}]]},
    "📊 Get Última Data TCM": {"main": [[{"node": "🔍 Comparar Datas", "type": "main", "index": 0}]]},
