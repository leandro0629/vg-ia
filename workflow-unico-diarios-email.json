      ]
    },
    "⬇️ Download PDF TCM": {"main": [[{"node": "☁️ Upload TCM", "type": "main", "index": 0}]]},
    "⬇️ Download PDF TCE": {"main": [[{"node": "☁️ Upload TCE", "type": "main", "index": 0}]]},
    "☁️ Upload TCM": {"main": [[{"node": "💾 Inserir TCM no Banco", "type": "main", "index": 0}]]},
    "☁️ Upload TCE": {"main": [[{"node": "💾 Inserir TCE no Banco", "type": "main", "index": 0}]]},
