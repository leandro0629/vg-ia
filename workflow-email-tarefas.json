{
  "name": "Email Notificação - Nova Tarefa",
  "nodes": [
    {
      "parameters": {},
      "id": "webhook_trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "webhookId": "webhook-tarefas",
      "method": "POST"
    },
    {
      "parameters": {
        "fromEmail": "{{ $env.FROM_EMAIL }}",
        "toEmail": "{{ $node['webhook_trigger'].json.destinatario_email }}",
        "subject": "📌 Nova Tarefa: {{ $node['webhook_trigger'].json.titulo }}",
        "emailType": "html",
        "htmlBody": "<html>\n<head>\n  <style>\n    body { font-family: 'Inter', sans-serif; background: #0B0B0C; color: #FFFFFF; padding: 20px; }\n    .container { background: #1A1A1D; border: 1px solid #2A2A2E; border-radius: 12px; padding: 30px; max-width: 600px; margin: 0 auto; }\n    .header { border-bottom: 2px solid #F59E0B; padding-bottom: 20px; margin-bottom: 20px; }\n    .title { font-size: 24px; font-weight: 700; color: #F59E0B; margin: 0; }\n    .subtitle { font-size: 14px; color: #A1A1AA; margin-top: 5px; }\n    .task-info { background: #121214; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid #F59E0B; }\n    .task-field { margin: 10px 0; }\n    .label { color: #A1A1AA; font-size: 12px; font-weight: 600; text-transform: uppercase; }\n    .value { color: #FFFFFF; font-size: 15px; margin-top: 3px; }\n    .button { background: #F59E0B; color: #0B0B0C; padding: 12px 24px; border-radius: 8px; text-decoration: none; display: inline-block; margin-top: 20px; font-weight: 600; }\n    .footer { margin-top: 30px; padding-top: 20px; border-top: 1px solid #2A2A2E; color: #A1A1AA; font-size: 12px; text-align: center; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1 class=\"title\">📌 Nova Tarefa Criada</h1>\n      <p class=\"subtitle\">Você tem uma nova tarefa atribuída</p>\n    </div>\n    \n    <div class=\"task-info\">\n      <div class=\"task-field\">\n        <div class=\"label\">Título</div>\n        <div class=\"value\">{{ $node['webhook_trigger'].json.titulo }}</div>\n      </div>\n      \n      <div class=\"task-field\">\n        <div class=\"label\">Descrição</div>\n        <div class=\"value\">{{ $node['webhook_trigger'].json.descricao || 'Sem descrição' }}</div>\n      </div>\n      \n      <div class=\"task-field\">\n        <div class=\"label\">Responsável</div>\n        <div class=\"value\">{{ $node['webhook_trigger'].json.responsavel || 'Não atribuído' }}</div>\n      </div>\n      \n      <div class=\"task-field\">\n        <div class=\"label\">Data de Vencimento</div>\n        <div class=\"value\">{{ $node['webhook_trigger'].json.data_vencimento || 'Sem prazo' }}</div>\n      </div>\n      \n      <div class=\"task-field\">\n        <div class=\"label\">Prioridade</div>\n        <div class=\"value\">{{ $node['webhook_trigger'].json.prioridade || 'Normal' }}</div>\n      </div>\n    </div>\n    \n    <a href=\"{{ $node['webhook_trigger'].json.link_tarefa }}\" class=\"button\">Ver Tarefa Completa</a>\n    \n    <div class=\"footer\">\n      <p>Esta é uma notificação automática do Sistema JUS IA</p>\n      <p>Não responda este email</p>\n    </div>\n  </div>\n</body>\n</html>"
      },
      "id": "email_sender",
      "name": "Enviar Email",
      "type": "n8n-nodes-base.emailSendGmail",
      "typeVersion": 2,
      "position": [
        550,
        300
      ],
      "credentials": {
        "gmailOAuth2": "gmail_credential"
      }
    }
  ],
  "connections": {
    "webhook_trigger": {
      "main": [
        [
          {
            "node": "email_sender",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {}
}
